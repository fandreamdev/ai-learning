# ===========================================
#  ProjectAlpha .gitignore
#  覆盖：Python(FastAPI) / Node(React+Vite) / 数据库 / Docker / IDE / OS
# ===========================================

# ---------- 通用：操作系统 ----------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------- 通用：编辑器 / IDE ----------
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.history/
.cursor/
.claude/

# ---------- 通用：日志 / 临时文件 ----------
*.log
logs/
*.pid
*.seed
*.tmp
tmp/
temp/

# ---------- 通用：环境变量 ----------
.env
.env.*
!.env.example
!.env.sample

# ===========================================
#  Python / FastAPI 后端
# ===========================================

# 字节码与缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 打包发布
build/
dist/
*.egg
*.egg-info/
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# 虚拟环境
.venv/
venv/
env/
ENV/
.python-version

# 依赖与锁文件缓存
.pip-cache/
pip-log.txt
pip-delete-this-directory.txt

# Poetry（保留 lock，忽略缓存）
.poetry-cache/

# 测试与覆盖率
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
nosetests.xml

# 类型检查 / Lint 缓存
.mypy_cache/
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# Alembic（保留 versions 与配置，忽略本地临时）
# 如需忽略迁移产物可解开下行注释
# backend/alembic/versions/__pycache__/

# ===========================================
#  Node / React / Vite 前端
# ===========================================

# 依赖
node_modules/
.pnp/
.pnp.js
.pnp.cjs
.yarn/cache
.yarn/install-state.gz

# 构建产物
dist/
dist-ssr/
build/
.next/
.nuxt/
out/

# Vite 缓存
.vite/

# 测试与覆盖率
coverage/
.nyc_output/

# TypeScript 构建缓存
*.tsbuildinfo

# ESLint / Prettier 缓存
.eslintcache
.stylelintcache

# 包管理器日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# MSW
public/mockServiceWorker.js

# ===========================================
#  数据库
# ===========================================

# 本地数据卷与备份
*.sqlite
*.sqlite3
*.db
*.sql.gz
mysql-data/
postgres-data/
data/

# 本地 dump（保留 init.sql 与 seeds/）
dump.sql
dump-*.sql

# ===========================================
#  Docker
# ===========================================

docker-compose.override.yml

# ===========================================
#  Claude Code / AI 工具
# ===========================================

.claude/
.cursor/
.windsurf/
