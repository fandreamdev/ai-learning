# =====================================================
# ProjectAlpha 前端环境变量示例
# 使用方法：cp .env.example .env，然后按需修改
# 注意：仅以 VITE_ 开头的变量才会被注入到客户端代码中
# =====================================================

# API 基础地址
# - 开发环境：可走 Vite 代理 (/api/v1)，或直连后端 (http://localhost:8000/api/v1)
# - 生产环境：通常走 Nginx 反向代理 (/api/v1)
VITE_API_BASE_URL=/api/v1

# 是否启用 MSW Mock（联调前阶段使用）
VITE_ENABLE_MOCK=false
