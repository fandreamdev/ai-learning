# EditorConfig 帮助开发者在不同编辑器与 IDE 之间维护一致的代码风格
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python: PEP8 推荐 4 空格缩进
[*.py]
indent_size = 4
max_line_length = 100

# Markdown: 保留尾随空格（用于换行）
[*.md]
trim_trailing_whitespace = false

# Makefile 必须用 tab
[Makefile]
indent_style = tab

# SQL
[*.sql]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2
