# =====================================================
# ProjectAlpha 后端环境变量示例
# 使用方法：cp .env.example .env，然后填入真实值
# =====================================================

# ---------- 应用 ----------
APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
APP_DEBUG=true

# ---------- 数据库 ----------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=1qa2ws3ed
DB_NAME=project_alpha

# 测试数据库（pytest 使用，需独立于业务库）
DB_NAME_TEST=project_alpha_test

# SQLAlchemy 连接串（如未设置则由上述变量自动拼接）
DATABASE_URL=mysql+pymysql://root:1qa2ws3ed@localhost:3306/project_alpha?charset=utf8mb4

# ---------- CORS ----------
# 开发期允许前端 Vite dev server 跨域；多个用逗号分隔
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---------- 日志 ----------
LOG_LEVEL=INFO
