{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0",
    "types": ["@playwright/test"]
  },
  "include": ["e2e", "playwright.config.ts"]
}
