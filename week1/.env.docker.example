# =====================================================
# ProjectAlpha Compose 环境变量
#
# 用法：
#   cp .env.docker.example .env.docker
#   # 修改 DB_PASSWORD 等
#   docker compose --env-file .env.docker up -d --build
# =====================================================

# MySQL root 密码（必填）
DB_PASSWORD=1qa2ws3ed

# 数据库名（默认 project_alpha / project_alpha_test）
DB_NAME=project_alpha
DB_NAME_TEST=project_alpha_test

# 容器端口暴露：
# - WEB_PORT：前端 Nginx 暴露端口（默认 80；80 被占用时改为 8080）
# - DB_PORT：MySQL 暴露端口（默认 3307，避免与本地原生 MySQL 3306 冲突）
WEB_PORT=80
DB_PORT=3307
